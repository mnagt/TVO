<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Search View -->
        <record id="view_tax_balance_line_search" model="ir.ui.view">
            <field name="name">account.tax.balance.line.search</field>
            <field name="model">account.tax.balance.line</field>
            <field name="arch" type="xml">
                <search string="Tax Balance by Tax">
                    <field name="partner_id"/>
                    <field name="name" string="Number"/>
                    <field name="ref" string="Reference"/>
                    <filter name="customers" string="Customers"
                            domain="[('move_type', 'in', ['out_invoice', 'out_refund'])]"/>
                    <filter name="vendors" string="Vendors"
                            domain="[('move_type', 'in', ['in_invoice', 'in_refund'])]"/>
                    <separator/>
                    <filter name="filter_date" string="Date" date="date"/>
                    <group expand="1" string="Group By">
                        <filter name="group_by_tax" string="Tax" context="{'group_by': 'tax_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- USD List View -->
        <record id="view_tax_balance_line_tree" model="ir.ui.view">
            <field name="name">account.tax.balance.line.tree</field>
            <field name="model">account.tax.balance.line</field>
            <field name="arch" type="xml">
                <list string="Tax Balance by Tax"
                      create="false" delete="false" edit="false"
                      js_class="tax_balance_by_tax">
                    <field name="name" string="Number"/>
                    <field name="partner_id" string="Partner"/>
                    <field name="date" string="Date"/>
                    <field name="ref" string="Reference"/>
                    <field name="tax_id" string="Tax"/>
                    <field name="amount_untaxed" string="Tax Excluded"
                           widget="monetary"
                           options="{'currency_field': 'company_currency_id'}"/>
                    <field name="tax_amount" string="Tax Amount"
                           widget="monetary"
                           options="{'currency_field': 'company_currency_id'}"
                           sum="Tax Total"/>
                    <field name="amount_total" string="Total"
                           widget="monetary"
                           options="{'currency_field': 'company_currency_id'}"/>
                    <field name="company_currency_id" column_invisible="True"/>
                    <field name="move_id" column_invisible="True"/>
                    <field name="move_type" column_invisible="True"/>
                </list>
            </field>
        </record>

        <!-- TRY List View -->
        <record id="view_tax_balance_line_tr_tree" model="ir.ui.view">
            <field name="name">account.tax.balance.line.tr.tree</field>
            <field name="model">account.tax.balance.line</field>
            <field name="arch" type="xml">
                <list string="Tax Balance TL by Tax"
                      create="false" delete="false" edit="false"
                      js_class="tax_balance_by_tax">
                    <field name="name" string="Number"/>
                    <field name="partner_id" string="Partner"/>
                    <field name="date" string="Date"/>
                    <field name="ref" string="Reference"/>
                    <field name="tax_id" string="Tax"/>
                    <field name="amount_untaxed_try" string="Tax Excluded"
                           widget="monetary"
                           options="{'currency_field': 'try_currency_id'}"/>
                    <field name="tax_amount_try" string="Tax Amount"
                           widget="monetary"
                           options="{'currency_field': 'try_currency_id'}"
                           sum="Tax Total"/>
                    <field name="amount_total_try" string="Total"
                           widget="monetary"
                           options="{'currency_field': 'try_currency_id'}"/>
                    <field name="try_currency_id" column_invisible="True"/>
                    <field name="move_id" column_invisible="True"/>
                    <field name="move_type" column_invisible="True"/>
                </list>
            </field>
        </record>

        <!-- USD Action -->
        <record id="action_tax_balance_by_tax" model="ir.actions.act_window">
            <field name="name">Tax Balance by Tax</field>
            <field name="res_model">account.tax.balance.line</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tax_balance_line_tree"/>
            <field name="search_view_id" ref="view_tax_balance_line_search"/>
            <field name="domain">[]</field>
            <field name="context">{'action_name': 'Tax Balance by Tax', 'search_default_group_by_tax': 1}</field>
        </record>

        <!-- TRY Action -->
        <record id="action_tax_balance_tr_by_tax" model="ir.actions.act_window">
            <field name="name">Tax Balance TL by Tax</field>
            <field name="res_model">account.tax.balance.line</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tax_balance_line_tr_tree"/>
            <field name="search_view_id" ref="view_tax_balance_line_search"/>
            <field name="domain">[]</field>
            <field name="context">{'action_name': 'Tax Balance TL by Tax', 'search_default_group_by_tax': 1}</field>
        </record>

    </data>
</odoo>

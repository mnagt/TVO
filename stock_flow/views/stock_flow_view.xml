<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        
        <record id="stock_product_flow_report_company_rule" model="ir.rule">
            <field name="name">Stock Product Flow Report: multi-company</field>
            <field name="model_id" ref="model_stock_product_flow_report"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="view_stock_move_line_report_tree" model="ir.ui.view">
            <field name="name">stock.product.flow.report.tree</field>
            <field name="model">stock.product.flow.report</field>
            <field name="arch" type="xml">
                <list default_order="date asc" create="false" js_class="stock_flow">
                    <field name="date"/>
                    <field name="product_id"/>
                    <field name="warehouse_id"/>
                    <field name="categ_id" optional="hide"/>
                    <field name="operation"/>
                    <field name="partner_id" optional="show"/>
                    <field name="location_id" string="From" optional="hide"/>
                    <field name="location_dest_id" string="To" optional="hide"/>
                    <field name="signed_qty_done" string="Quantity"/>
                    <field name="stock_balance"/>
                </list>
            </field>
        </record>

        <record id="view_stock_move_line_report_search" model="ir.ui.view">
            <field name="name">stock.product.flow.report.search</field>
            <field name="model">stock.product.flow.report</field>
            <field name="arch" type="xml">
                <search>
                    <!-- Default search filters -->
                    <field name="product_id"/>
                    <field name="operation"/>
                    <field name="direction"/>
                    <field name="partner_id"/>
                    <field name="date"/>

                    <!-- Group By section -->
                    <group expand="0" string="Group By">
                        <filter name="group_by_warehouse" string="Warehouse" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                        <filter name="group_by_product" string="Product" domain="[]" context="{'group_by': 'product_id'}"/>
                        <filter name="group_by_categ" string="Product Category" domain="[]" context="{'group_by': 'categ_id'}"/>
                        <filter name="group_by_date" string="Date" domain="[]" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>



        <record id="action_stock_move_line_report" model="ir.actions.act_window">
            <field name="name">Stock Product Flow</field>
            <field name="res_model">stock.product.flow.report</field>
            <field name="view_mode">list</field>
            <field name="search_view_id" ref="stock_flow.view_stock_move_line_report_search"/>
        </record>


        <menuitem id="menu_stock_move_line_report"
                    name="Stock Flow"
                    parent="stock.menu_warehouse_report"
                    action="action_stock_move_line_report"
                    sequence="160"/>



    </data>
</odoo>

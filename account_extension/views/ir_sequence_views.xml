<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action for accounting sequences -->
    <record id="action_account_sequence" model="ir.actions.act_window">
        <field name="name">Sequences</field>
        <field name="res_model">ir.sequence</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('code', 'like', 'account')]</field>
    </record>

    <!-- Restore Settings as first child (account.menu_account_config was a leaf) -->
    <menuitem
        id="menu_account_settings"
        name="Settings"
        parent="account.menu_account_config"
        action="account.action_account_config"
        groups="account.group_account_manager"
        sequence="1"/>

    <!-- Menu item under Accounting > Configuration -->
    <menuitem
        id="menu_account_sequence"
        name="Sequences"
        parent="account.menu_account_config"
        action="action_account_sequence"
        groups="account.group_account_manager"
        sequence="2"/>

</odoo>
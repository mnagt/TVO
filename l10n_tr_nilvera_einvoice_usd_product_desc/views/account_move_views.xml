<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_product_desc_column" model="ir.ui.view">
        <field name="name">account.move.form.product.desc.column</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='name']" position="after">
                <field name="nilvera_product_desc" column_invisible="not parent.l10n_tr_product_desc"/>
            </xpath>
        </field>
    </record>
</odoo>

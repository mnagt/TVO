<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_nilvera_product_desc" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.nilvera.product.desc</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_tr_nilvera_einvoice_usd.res_config_settings_view_form_nilvera_usd"/>
        <field name="arch" type="xml">
            <block id="nilvera" position="inside">
                <setting string="Product Description Fields"
                         help="Show Nilvera product description fields on products and invoices (per company)">
                    <field name="l10n_tr_product_desc" widget="boolean_toggle"/>
                </setting>
            </block>
        </field>
    </record>
</odoo>
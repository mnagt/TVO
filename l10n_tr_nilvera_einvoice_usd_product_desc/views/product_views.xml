<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_nilvera_desc" model="ir.ui.view">
        <field name="name">product.template.form.nilvera.desc</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoicing']//group[@name='accounting']" position="after">
                <group string="Nilvera">
                    <field name="nilvera_product_desc"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_logistics_pre_notification_form" model="ir.ui.view">
        <field name="name">logistics.pre.notification.form</field>
        <field name="model">logistics.pre.notification</field>
        <field name="arch" type="xml">
            <form string="Pre-Notification">
                <sheet>
                    <group>
                        <group>
                            <field name="importer_id"/>
                            <field name="exporter_id"/>
                            <field name="manufacturer_id"/>
                        </group>
                        <group>
                            <field name="product_name"/>
                            <field name="notification_code"/>
                        </group>
                    </group>
                    <group>
                        <field name="product_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_logistics_pre_notification_list" model="ir.ui.view">
        <field name="name">logistics.pre.notification.list</field>
        <field name="model">logistics.pre.notification</field>
        <field name="arch" type="xml">
            <list>
                <field name="importer_id"/>
                <field name="exporter_id"/>
                <field name="product_name"/>
                <field name="notification_code"/>
            </list>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_logistics_transit_trip_form" model="ir.ui.view">
        <field name="name">logistics.transit.trip.form</field>
        <field name="model">logistics.transit.trip</field>
        <field name="arch" type="xml">
            <form string="Transit Trip">
                <header>
                    <button name="action_start" string="Start Transit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_deliver" string="Deliver" type="object"
                            class="btn-primary" invisible="state != 'in_transit'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_transit,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="plaka_no"/>
                        </group>
                        <group>
                            <field name="departure_date"/>
                            <field name="arrival_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Container Lines" name="container_lines">
                            <field name="container_line_ids">
                                <list>
                                    <field name="internal_ref"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="container_id"/>
                                    <field name="wh_arriving_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_logistics_transit_trip_list" model="ir.ui.view">
        <field name="name">logistics.transit.trip.list</field>
        <field name="model">logistics.transit.trip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="plaka_no"/>
                <field name="departure_date"/>
                <field name="arrival_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_transit'"
                       decoration-success="state == 'delivered'"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_logistics_transit_trip_pivot" model="ir.ui.view">
        <field name="name">logistics.transit.trip.pivot</field>
        <field name="model">logistics.transit.trip</field>
        <field name="arch" type="xml">
            <pivot string="Transit Trips">
                <field name="state" type="row"/>
                <field name="departure_date" interval="month" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_logistics_transit_trip_search" model="ir.ui.view">
        <field name="name">logistics.transit.trip.search</field>
        <field name="model">logistics.transit.trip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="plaka_no"/>
                <separator/>
                <filter name="state_draft" string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="state_in_transit" string="In Transit"
                        domain="[('state','=','in_transit')]"/>
                <filter name="state_delivered" string="Delivered"
                        domain="[('state','=','delivered')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>

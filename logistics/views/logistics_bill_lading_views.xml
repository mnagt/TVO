<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_logistics_bill_lading_form" model="ir.ui.view">
        <field name="name">logistics.bill.lading.form</field>
        <field name="model">logistics.bill.lading</field>
        <field name="arch" type="xml">
            <form string="Bill of Lading">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_ship" string="Ship" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_in_transit" string="In Transit" type="object"
                            class="btn-primary" invisible="state != 'shipped'"/>
                    <button name="action_arrived" string="Arrived" type="object"
                            class="btn-primary" invisible="state != 'in_transit'"/>
                    <button name="action_deliver" string="Deliver" type="object"
                            class="btn-primary" invisible="state != 'arrived'"/>
                    <button name="action_close" string="Close" type="object"
                            class="btn-primary" invisible="state != 'delivered'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,shipped,in_transit,arrived,delivered,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_containers" icon="fa-cubes">
                            <field string="Containers" name="container_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="number"/>
                            <field name="bl_date"/>
                            <field name="bl_draft"/>
                        </group>
                        <group>
                            <field name="forwarder_id"/>
                            <field name="shipping_line_id"/>
                            <field name="ccl_company_id"/>
                            <field name="vessel"/>
                            <field name="incoterm_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="port_of_loading_id"/>
                            <field name="departure_date"/>
                        </group>
                        <group>
                            <field name="port_of_discharge_id"/>
                            <field name="arrival_date"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="docs_draft"/>
                            <field name="docs_original"/>
                            <field name="bl_original_release"/>
                            <field name="ordino"/>
                            <field name="custom_declaration"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Containers" name="containers">
                            <field name="container_ids">
                                <list>
                                    <field name="container_number"/>
                                    <field name="container_type"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Import Deals" name="import_deals">
                            <field name="requisition_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="vendor_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_logistics_bill_lading_list" model="ir.ui.view">
        <field name="name">logistics.bill.lading.list</field>
        <field name="model">logistics.bill.lading</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="number"/>
                <field name="bl_date"/>
                <field name="forwarder_id"/>
                <field name="ccl_company_id" optional="hide"/>
                <field name="vessel"/>
                <field name="port_of_loading_id"/>
                <field name="port_of_discharge_id"/>
                <field name="departure_date"/>
                <field name="arrival_date"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('draft','confirmed')"
                       decoration-warning="state in ('shipped','in_transit')"
                       decoration-success="state in ('arrived','delivered','closed')"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_logistics_bill_lading_pivot" model="ir.ui.view">
        <field name="name">logistics.bill.lading.pivot</field>
        <field name="model">logistics.bill.lading</field>
        <field name="arch" type="xml">
            <pivot string="Bills of Lading">
                <field name="forwarder_id" type="row"/>
                <field name="shipping_line_id" type="row"/>
                <field name="departure_date" interval="month" type="col"/>
                <field name="container_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_logistics_bill_lading_search" model="ir.ui.view">
        <field name="name">logistics.bill.lading.search</field>
        <field name="model">logistics.bill.lading</field>
        <field name="arch" type="xml">
            <search>
                <field name="number"/>
                <field name="vessel"/>
                <field name="forwarder_id"/>
                <separator/>
                <filter name="state_draft" string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="state_confirmed" string="Confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter name="state_shipped" string="Shipped"
                        domain="[('state','=','shipped')]"/>
                <filter name="state_in_transit" string="In Transit"
                        domain="[('state','=','in_transit')]"/>
                <filter name="state_arrived" string="Arrived"
                        domain="[('state','=','arrived')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_forwarder" string="Forwarder"
                            context="{'group_by': 'forwarder_id'}"/>
                    <filter name="group_port_discharge" string="Port of Discharge"
                            context="{'group_by': 'port_of_discharge_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_logistics_bill_lading_kanban" model="ir.ui.view">
        <field name="name">logistics.bill.lading.kanban</field>
        <field name="model">logistics.bill.lading</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <field name="number"/>
                <field name="vessel"/>
                <field name="arrival_date"/>
                <field name="container_count"/>
                <templates>
                    <t t-name="card">
                        <field name="number" class="fw-bold"/>
                        <field name="vessel"/>
                        ETA: <field name="arrival_date"/>
                        <field name="container_count"/> containers
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_registration_form" model="ir.ui.view">
        <field name="name">product.registration.form</field>
        <field name="model">product.registration</field>
        <field name="arch" type="xml">
            <form string="Product Registration">
                <sheet>
                    <group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="country_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="registration_date"/>
                            <field name="registration_file" widget="url"/>
                            <field name="market_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_product_registration_list" model="ir.ui.view">
        <field name="name">product.registration.list</field>
        <field name="model">product.registration</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_tmpl_id"/>
                <field name="country_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'registered'"
                       decoration-warning="status == 'pending'"
                       decoration-info="status == 'to_be_registered'"
                       decoration-danger="status == 'not_registered'"/>
                <field name="registration_date"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_product_registration_search" model="ir.ui.view">
        <field name="name">product.registration.search</field>
        <field name="model">product.registration</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_tmpl_id"/>
                <field name="country_id"/>
                <separator/>
                <filter name="registered" string="Registered"
                        domain="[('status','=','registered')]"/>
                <filter name="pending" string="Pending"
                        domain="[('status','=','pending')]"/>
                <filter name="to_be_registered" string="To Be Registered"
                        domain="[('status','=','to_be_registered')]"/>
                <filter name="not_registered" string="Not Registered"
                        domain="[('status','=','not_registered')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_country" string="Country"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>

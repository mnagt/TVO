<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Report Views ===== -->

    <!-- 7.1 Purchase Trends — pivot -->
    <record id="view_container_line_pivot_trends" model="ir.ui.view">
        <field name="name">logistics.container.line.pivot.trends</field>
        <field name="model">logistics.container.line</field>
        <field name="arch" type="xml">
            <pivot string="Purchase Trends" disable_linking="True">
                <field name="product_id" type="row"/>
                <field name="pi_date" interval="month" type="col"/>
                <field name="total_weight" type="measure"/>
                <field name="product_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- 7.1 Purchase Trends — graph -->
    <record id="view_container_line_graph_trends" model="ir.ui.view">
        <field name="name">logistics.container.line.graph.trends</field>
        <field name="model">logistics.container.line</field>
        <field name="arch" type="xml">
            <graph string="Purchase Trends" type="line">
                <field name="pi_date" interval="month" type="row"/>
                <field name="total_weight" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- 7.2 SKU Pipeline — pivot -->
    <record id="view_container_line_pivot_pipeline" model="ir.ui.view">
        <field name="name">logistics.container.line.pivot.pipeline</field>
        <field name="model">logistics.container.line</field>
        <field name="arch" type="xml">
            <pivot string="SKU Pipeline" disable_linking="True">
                <field name="product_id" type="row"/>
                <field name="container_id" type="col"/>
                <field name="product_qty" type="measure"/>
                <field name="total_weight" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- 7.3 Supplier Departures — list -->
    <record id="view_container_line_list_departures" model="ir.ui.view">
        <field name="name">logistics.container.line.list.departures</field>
        <field name="model">logistics.container.line</field>
        <field name="arch" type="xml">
            <list string="Supplier Departures" default_group_by="vendor_id">
                <field name="vendor_id" optional="show"/>
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="total_weight"/>
                <field name="bl_departure_date"/>
                <field name="bl_arrival_date"/>
                <field name="invoice_no"/>
                <field name="available_to_sale_date"/>
                <field name="collection_date"/>
            </list>
        </field>
    </record>

    <!-- 7.4 Oils / Oleochemicals — shared pivot -->
    <record id="view_container_line_pivot_category_summary" model="ir.ui.view">
        <field name="name">logistics.container.line.pivot.category.summary</field>
        <field name="model">logistics.container.line</field>
        <field name="arch" type="xml">
            <pivot string="Category Summary" disable_linking="True">
                <field name="product_id" type="row"/>
                <field name="pi_date" interval="month" type="col"/>
                <field name="total_weight" type="measure"/>
                <field name="product_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ===== Report Actions ===== -->

    <record id="action_report_purchase_trends" model="ir.actions.act_window">
        <field name="name">Purchase Trends</field>
        <field name="res_model">logistics.container.line</field>
        <field name="view_mode">pivot,graph</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_container_line_pivot_trends')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_container_line_graph_trends')}),
        ]"/>
    </record>

    <record id="action_report_sku_pipeline" model="ir.actions.act_window">
        <field name="name">SKU Pipeline</field>
        <field name="res_model">logistics.container.line</field>
        <field name="view_mode">pivot</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_container_line_pivot_pipeline')}),
        ]"/>
    </record>

    <record id="action_report_supplier_departures" model="ir.actions.act_window">
        <field name="name">Supplier Departures</field>
        <field name="res_model">logistics.container.line</field>
        <field name="view_mode">list</field>
        <field name="context">{'group_by': 'vendor_id'}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_container_line_list_departures')}),
        ]"/>
    </record>

    <record id="action_report_oils_summary" model="ir.actions.act_window">
        <field name="name">Oils Summary</field>
        <field name="res_model">logistics.container.line</field>
        <field name="view_mode">pivot</field>
        <field name="domain">[('category_id.name', 'ilike', 'Oil')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_container_line_pivot_category_summary')}),
        ]"/>
    </record>

    <record id="action_report_oleochem_summary" model="ir.actions.act_window">
        <field name="name">Oleochemicals Summary</field>
        <field name="res_model">logistics.container.line</field>
        <field name="view_mode">pivot</field>
        <field name="domain">[('category_id.name', 'ilike', 'Oleo')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_container_line_pivot_category_summary')}),
        ]"/>
    </record>

</odoo>

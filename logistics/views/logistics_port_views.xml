<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_logistics_port_form" model="ir.ui.view">
        <field name="name">logistics.port.form</field>
        <field name="model">logistics.port</field>
        <field name="arch" type="xml">
            <form string="Port">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="country_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_logistics_port_list" model="ir.ui.view">
        <field name="name">logistics.port.list</field>
        <field name="model">logistics.port</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="country_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_logistics_port_search" model="ir.ui.view">
        <field name="name">logistics.port.search</field>
        <field name="model">logistics.port</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

</odoo>

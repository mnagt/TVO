<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cheque_transfer_wizard_form" model="ir.ui.view">
        <field name="name">cheque.transfer.wizard.form</field>
        <field name="model">cheque.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Transfer Cheque to Warranty">
                <group string="Current Deposit Info">
                    <field name="cheque_id" readonly="1"/>
                    <field name="deposit_journal_id" readonly="1"/>
                    <field name="collection_account_id" readonly="1"/>
                </group>
                <group string="Transfer To">
                    <field name="transfer_account_id"/>
                    <field name="date"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight"/>
                    or <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cheque_transfer_wizard_view" model="ir.actions.act_window">
        <field name="name">Transfer Cheque</field>
        <field name="res_model">cheque.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

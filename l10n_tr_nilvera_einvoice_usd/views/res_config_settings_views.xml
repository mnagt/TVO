<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_nilvera_usd" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.nilvera.usd</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <block id="nilvera" position="inside">
                <h2>Nilvera E-Invoice (USD)</h2>
                <setting string="USD Mode"
                         help="Enable USD-specific currency conversion logic in XML generation">
                    <field name="l10n_tr_usd_mode" widget="boolean_toggle"/>
                </setting>
            </block>
        </field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <delete model="ir.ui.view" id="view_move_form_edespatch_picking"/>
    <delete model="ir.ui.view" search="[('name', '=', 'product.template.form.nilvera.desc')]"/>

    <record id="view_move_form_tcmb_rate_type" model="ir.ui.view">
        <field name="name">account.move.form.tcmb.rate.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='currency_div']//field[@name='currency_id']" position="after">
                <field name="l10n_tr_nilvera_customer_status" widget="badge"
                        class="ms-2"
                        decoration-info="l10n_tr_nilvera_customer_status == 'einvoice'"
                        decoration-success="l10n_tr_nilvera_customer_status == 'earchive'"
                        invisible="move_type not in ('out_invoice', 'out_refund')
                                    or l10n_tr_nilvera_customer_status == 'not_checked'"
                        readonly="1"/>
            </xpath>

        </field>
    </record>



</odoo>





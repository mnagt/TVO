        <field name="name">res.config.settings.view.form.nilvera.draft.after.sent</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_tr_nilvera_einvoice_usd.res_config_settings_view_form_nilvera_usd"/>
        <field name="arch" type="xml">
            <block id="nilvera" position="inside">
                <setting string="Allow Draft After Sent"
                         help="Allow resetting submitted invoices to draft state (per company)">
                    <field name="l10n_tr_draft_after_sent" widget="boolean_toggle"/>
                </setting>
            </block>
        </field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend the standard sale order report to add bank account information -->
    <template id="report_saleorder_document_bank_accounts"
              inherit_id="sale.report_saleorder_document">

        <!-- Insert bank account table after the note section -->
        <xpath expr="//span[@t-field='doc.note']" position="after">
            <t t-if="doc.bank_account_ids">
                <div class="mt-4">
                    <h5 style="font-weight: bold; margin-bottom: 10px;">
                        Bank Account Information
                    </h5>

                    <table class="table table-sm table-bordered"
                           style="font-size: 10px; width: 100%;">
                        <thead>
                            <tr style="background-color: #f8f9fa;">
                                <th style="padding: 8px; text-align: left;">IBAN</th>
                                <th style="padding: 8px; text-align: left;">Bank Name</th>
                                <th style="padding: 8px; text-align: left;">Currency</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.bank_account_ids" t-as="bank">
                                <tr>
                                    <td style="padding: 6px;">
                                        <t t-esc="bank.acc_number or '-'"/>
                                    </td>
                                    <td style="padding: 6px;">
                                        <t t-esc="bank.bank_id.name if bank.bank_id else '-'"/>
                                    </td>
                                    <td style="padding: 6px;">
                                        <t t-esc="bank.currency_id.name if bank.currency_id else '-'"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </xpath>
    </template>
</odoo>

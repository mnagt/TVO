<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Add TL/USD toolbar to USD General Ledger view -->
    <record id="view_move_line_tree_grouped_general_toolbar" model="ir.ui.view">
        <field name="name">account.move.line.list.grouped.general.toolbar</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree_grouped_general"/>
        <field name="arch" type="xml">
            <list name="move_line_tree" position="attributes">
                <attribute name="js_class">general_ledger_tl</attribute>
            </list>
        </field>
    </record>

    <!-- TL General Ledger View -->
    <record id="view_move_line_tree_grouped_general_tl" model="ir.ui.view">
        <field name="name">account.move.line.list.grouped.general.tl</field>
        <field name="model">account.move.line</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_move_line_tree_grouped_general"/>
        <field name="arch" type="xml">
            <!-- Activate custom JS controller for TL/USD toolbar -->
            <list name="move_line_tree" position="attributes">
                <attribute name="js_class">general_ledger_tl</attribute>
            </list>
            <!-- In TL view: show amount_currency, but hide per-row when currency is TRY -->
            <field name="amount_currency" position="attributes">
                <attribute name="optional">show</attribute>
                <attribute name="invisible">currency_id == tr_currency_id</attribute>
            </field>

            <!-- Swap debit column: USD → TL -->
            <field name="debit" position="replace">
                <field name="tr_currency_id" optional="hide"/>
                <field name="tr_debit" string="Debit" optional="show" readonly="1"/>
            </field>
            <!-- Swap credit column: USD → TL -->
            <field name="credit" position="replace">
                <field name="tr_credit" string="Credit" optional="show" readonly="1"/>
            </field>
            <!-- Replace balance with cumulated TL balance only (amount_tr_currency already exists from try_fields) -->
            <field name="balance" position="replace">
                <field name="cumulated_tr_balance" string="Cumulated Balance" optional="show" readonly="1"/>
            </field>
        </field>
    </record>

    <!-- TL General Ledger Action -->
    <record id="action_account_moves_ledger_general_tl" model="ir.actions.act_window">
        <field name="name">General Ledger (TL)</field>
        <field name="res_model">account.move.line</field>
        <field name="domain">[('display_type', 'not in', ('line_section', 'line_note'))]</field>
        <field name="view_id" ref="account_extension_tl_gl.view_move_line_tree_grouped_general_tl"/>
        <field name="search_view_id" ref="account.view_account_move_line_filter"/>
        <field name="view_mode">list,pivot,graph</field>
        <field name="context">{
            'journal_type': 'general',
            'search_default_group_by_account': 1,
            'search_default_posted': 1,
            'tl_gl_view': True
        }</field>
    </record>

</odoo>
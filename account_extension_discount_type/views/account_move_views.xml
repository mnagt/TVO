<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_discount_type" model="ir.ui.view">
        <field name="name">account.move.form.discount.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="discount" position="attributes">
                <attribute name="invisible">False</attribute>
                <attribute name="readonly">discount_type == 'fixed'</attribute>
            </field>
            <field name="discount" position="after">
                <field name="discount_type" optional="show" width="70px" string="Disc.Type"/>
                <field name="discount_fixed" optional="hide"
                       invisible="discount_type == 'percentage'" string="Disc.Fixed"/>
            </field>
        </field>
    </record>
</odoo>

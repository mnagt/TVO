<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- 1. Company: global unconditional, applies to everyone -->
        <record id="rule_product_balance_report_company" model="ir.rule">
            <field name="name">Product Balance: Multi-Company</field>
            <field name="model_id" ref="model_product_balance_report"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- 2. Accounting: full access, no ownership restriction -->
        <record id="rule_product_balance_report_accounting" model="ir.rule">
            <field name="name">Product Balance: Accounting Full Access</field>
            <field name="model_id" ref="model_product_balance_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_manager')), (4, ref('account.group_account_user'))]"/>
        </record>

        <!-- 3. Salesperson: own invoices only -->
        <record id="rule_product_balance_report_sale_personal" model="ir.rule">
            <field name="name">Product Balance: Personal Sales</field>
            <field name="model_id" ref="model_product_balance_report"/>
            <field name="domain_force">['|', ('salesperson_id', '=', user.id), ('salesperson_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <!-- 4. Salesperson: own + team invoices -->
        <record id="rule_product_balance_report_sale_team" model="ir.rule">
            <field name="name">Product Balance: Team Sales</field>
            <field name="model_id" ref="model_product_balance_report"/>
            <field name="domain_force">['|', '|', ('salesperson_id', '=', user.id), ('salesperson_id', '=', False), '|', ('salesperson_id.sale_team_id', '=', user.sale_team_id.id), ('salesperson_id.sale_team_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('sale_extension_team_security.group_sale_team_manager'))]"/>
        </record>

        <!-- 5. Salesperson: see all -->
        <record id="rule_product_balance_report_sale_all" model="ir.rule">
            <field name="name">Product Balance: All Sales</field>
            <field name="model_id" ref="model_product_balance_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
        </record>

    </data>
</odoo>

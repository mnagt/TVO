<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_partner_balance_user" model="res.groups">
            <field name="name">Partner Balance: Access</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <record id="rule_account_move_line_report_company" model="ir.rule">
            <field name="name">Account Move Line Report: multi-company</field>
            <field name="model_id" ref="model_account_move_line_report"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_account_aged_balance_line_company" model="ir.rule">
            <field name="name">Account Aged Balance Line: multi-company</field>
            <field name="model_id" ref="model_account_aged_balance_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Search View -->
    <record id="view_aged_balance_line_search" model="ir.ui.view">
        <field name="name">account.aged.balance.line.search</field>
        <field name="model">account.aged.balance.line</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter name="group_by_bucket"  string="Bucket"  context="{'group_by': 'bucket'}"/>
                    <filter name="group_by_account" string="Account" context="{'group_by': 'account_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- USD List View -->
    <record id="view_aged_balance_line_tree" model="ir.ui.view">
        <field name="name">account.aged.balance.line.tree</field>
        <field name="model">account.aged.balance.line</field>
        <field name="arch" type="xml">
            <list string="Aged Balance"
                  create="false" delete="false" edit="false"
                  js_class="partner_balance"
                  decoration-danger="days_overdue > 0 and line_type == 'summary'"
                  decoration-info="line_type == 'product'">
                <field name="reference"      string="Document"/>
                <field name="date"           string="Date"/>
                <field name="date_maturity"  string="Due Date"/>
                <field name="days_overdue"   string="Days"/>
                <field name="amount_residual" string="Residual"/>
                <field name="bucket_display"  string="Bucket"/>
                <!-- hidden -->
                <field name="company_currency_id" column_invisible="True"/>
                <field name="line_type"      column_invisible="True"/>
                <field name="type_key"       column_invisible="True"/>
                <field name="move_id"        column_invisible="True"/>
                <field name="bucket"         column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- TRY List View -->
    <record id="view_aged_balance_line_tr_tree" model="ir.ui.view">
        <field name="name">account.aged.balance.line.tr.tree</field>
        <field name="model">account.aged.balance.line</field>
        <field name="arch" type="xml">
            <list string="Aged Balance (TRY)"
                  create="false" delete="false" edit="false"
                  js_class="partner_balance"
                  decoration-danger="days_overdue > 0 and line_type == 'summary'"
                  decoration-info="line_type == 'product'">
                <field name="reference"           string="Document"/>
                <field name="date"                string="Date"/>
                <field name="date_maturity"       string="Due Date"/>
                <field name="days_overdue"        string="Days"/>
                <field name="amount_residual_try" string="TRY Residual"/>
                <field name="tr_rate_display"     string="Rate"/>
                <field name="bucket_display"      string="Bucket"/>
                <!-- hidden -->
                <field name="tr_currency_id"      column_invisible="True"/>
                <field name="company_currency_id" column_invisible="True"/>
                <field name="line_type"           column_invisible="True"/>
                <field name="type_key"            column_invisible="True"/>
                <field name="move_id"             column_invisible="True"/>
                <field name="bucket"              column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- USD Action -->
    <record id="action_aged_balance" model="ir.actions.act_window">
        <field name="name">Aged Balance</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.aged.balance.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="partner_balance.view_aged_balance_line_tree"/>
        <field name="views" eval="[(ref('partner_balance.view_aged_balance_line_tree'), 'list')]"/>
        <field name="target">current</field>
        <field name="domain">[('partner_id', '=', active_id), ('line_type', '=', 'summary')]</field>
        <field name="context">{
            'report_type': 'aged',
            'search_default_group_by_bucket': 1
        }</field>
    </record>

    <!-- TRY Action -->
    <record id="action_aged_balance_tr" model="ir.actions.act_window">
        <field name="name">Aged Balance in TRY</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.aged.balance.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="partner_balance.view_aged_balance_line_tr_tree"/>
        <field name="views" eval="[(ref('partner_balance.view_aged_balance_line_tr_tree'), 'list')]"/>
        <field name="target">current</field>
        <field name="domain">[('partner_id', '=', active_id), ('line_type', '=', 'summary')]</field>
        <field name="context">{
            'report_type': 'aged',
            'search_default_group_by_bucket': 1,
            'action_name': 'Statement in TRY'
        }</field>
    </record>

    <!-- Aged Balance Summary Search View -->
    <record id="view_aged_balance_summary_search" model="ir.ui.view">
        <field name="name">account.aged.balance.summary.search</field>
        <field name="model">account.aged.balance.summary</field>
        <field name="arch" type="xml">
            <search>
                <filter name="customers" string="Customers" domain="[('is_customer', '=', True)]"/>
                <filter name="vendors"   string="Vendors"   domain="[('is_vendor',   '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="view_aged_balance_summary_tree" model="ir.ui.view">
        <field name="name">account.aged.balance.summary.tree</field>
        <field name="model">account.aged.balance.summary</field>
        <field name="arch" type="xml">
            <list string="Aged Balance Summary" create="false" delete="false" edit="false"
                  js_class="aged_balance_summary">
                <field name="partner_id"    string="Partner"/>
                <field name="amount_current" string="Current"   widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_1_30"    string="1-30"       widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_31_60"   string="31-60"      widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_61_90"   string="61-90"      widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_91_120"  string="91-120"     widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_older"   string="&gt;120"    widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="amount_total"   string="Total"      widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                <field name="company_currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- TRY Summary View -->
    <record id="view_aged_balance_summary_tr_tree" model="ir.ui.view">
        <field name="name">account.aged.balance.summary.tr.tree</field>
        <field name="model">account.aged.balance.summary</field>
        <field name="arch" type="xml">
            <list string="Aged Balance Summary TL" create="false" delete="false" edit="false"
                  js_class="aged_balance_summary">
                <field name="partner_id" string="Partner"/>
                <field name="amount_current_try"  string="Current"  widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_1_30_try"     string="1-30"     widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_31_60_try"    string="31-60"    widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_61_90_try"    string="61-90"    widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_91_120_try"   string="91-120"   widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_older_try"    string="&gt;120"  widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="amount_total_try"    string="Total"    widget="monetary" options="{'currency_field': 'try_currency_id'}"/>
                <field name="try_currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- TRY Action -->
    <record id="action_aged_balance_summary_tr" model="ir.actions.act_window">
        <field name="name">Aged Balance TL</field>
        <field name="res_model">account.aged.balance.summary</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aged_balance_summary_tr_tree"/>
        <field name="search_view_id" ref="view_aged_balance_summary_search"/>
        <field name="domain">[]</field>
        <field name="context">{'action_name': 'Aged Balance in TRY'}</field>
    </record>

    <record id="action_aged_balance_summary" model="ir.actions.act_window">
        <field name="name">Aged Balance</field>
        <field name="res_model">account.aged.balance.summary</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aged_balance_summary_tree"/>
        <field name="search_view_id" ref="view_aged_balance_summary_search"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="menu_aged_balance_summary"
        name="Aged Balance"
        parent="account.account_reports_partners_reports_menu"
        action="action_aged_balance_summary"
        groups="account.group_account_manager,account.group_account_user"
        sequence="20"/>

</odoo>
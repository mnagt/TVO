<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_balance_list" model="ir.ui.view">
        <field name="name">res.partner.partner_balance.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false" js_class="partner_balance_sale">
                <field name="name" string="Customer"/>
                <field name="partner_balance" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_partner_balance_search" model="ir.ui.view">
        <field name="name">res.partner.partner_balance.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Partner Balance">
                <field name="name" string="Customer"/>
                <field name="user_id" string="Salesperson"/>
            </search>
        </field>
    </record>

    <record id="action_partner_balance_list" model="ir.actions.act_window">
        <field name="name">Partner Balance</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_balance_list"/>
        <field name="search_view_id" ref="view_partner_balance_search"/>
        <field name="domain">[('sale_order_ids', '!=', False)]</field>
        <field name="context">{'partner_balance_sale_filter': True}</field>
    </record>

    <menuitem
        id="menu_partner_balance_list"
        name="Partner Balance"
        parent="sale.menu_sale_report"
        action="action_partner_balance_list"
        sequence="50"
        groups="partner_balance.group_partner_balance_user"
    />

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_tcmb_try_rate" model="ir.ui.view">
        <field name="name">account.move.form.tcmb.try.rate</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="l10n_tr_is_third_currency" invisible="1"/>
                <field name="l10n_tr_tcmb_try_rate"
                    invisible="move_type not in ('out_invoice','out_refund','in_invoice','in_refund') or not l10n_tr_is_third_currency"
                    readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>

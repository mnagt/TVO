<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_res_users_balance_config" model="ir.ui.view">
            <field name="name">res.users.balance.config.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']" position="inside">
                    <separator string="PARTNER BALANCE REPORT"/>
                    <group>
                        <group>
                            <field name="pb_show_ledger"/>
                            <field name="pb_show_excel"/>
                            <field name="pb_show_usd"/>
                            <field name="pb_show_skip_opening"/>
                        </group>
                        <group>
                            <field name="pb_show_aged"/>
                            <field name="pb_show_tl"/>
                            <field name="pb_show_products"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
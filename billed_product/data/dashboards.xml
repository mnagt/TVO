<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="dashboard_vendor_bills" model="spreadsheet.dashboard">
    <field name="name">Vendor Bills</field>
    <field name="spreadsheet_binary_data" type="base64"
           file="billed_product/data/files/vendor_bills_dashboard.json"/>
    <field name="main_data_model_ids" eval="[(4, ref('account.model_account_move'))]"/>
    <field name="dashboard_group_id" ref="spreadsheet_dashboard.spreadsheet_dashboard_group_finance"/>
    <field name="group_ids" eval="[Command.link(ref('billed_product.group_vendor_bill_report'))]"/>
    <field name="sequence">30</field>
    <field name="is_published">True</field>
  </record>

  <record id="dashboard_customer_invoices" model="spreadsheet.dashboard">
    <field name="name">Customer Invoices</field>
    <field name="spreadsheet_binary_data" type="base64"
           file="billed_product/data/files/customer_invoices_dashboard.json"/>
    <field name="main_data_model_ids" eval="[(4, ref('account.model_account_move'))]"/>
    <field name="dashboard_group_id" ref="spreadsheet_dashboard.spreadsheet_dashboard_group_finance"/>
    <field name="group_ids" eval="[Command.link(ref('billed_product.group_customer_invoice_report'))]"/>
    <field name="sequence">31</field>
    <field name="is_published">True</field>
  </record>
</odoo>
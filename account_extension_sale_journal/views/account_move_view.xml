<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Search view: sale order field + group_by filter -->
    <record id="view_account_move_line_filter" model="ir.ui.view">
        <field name="name">Journal Items (Sale Order)</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="sale_order_id"/>
            </field>
            <filter name="group_by_partner" position="after">
                <filter
                    name="group_by_sale_order"
                    string="Sale Order"
                    domain="[]"
                    context="{'group_by':'sale_order_id'}"
                />
            </filter>
        </field>
    </record>

    <!-- List view: sale order column -->
    <record id="view_move_line_tree_sale_order" model="ir.ui.view">
        <field name="name">account.move.line.tree.sale.order</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="amount_currency" position="after">
                <field name="sale_order_id" optional="show"/>
            </field>
        </field>
    </record>
</odoo>